# AI Studio — Environment Variables
# Copy this to .env and customize as needed.

# --- Infrastructure (require container restart) ---

# Host port mapped to the container (default: 3001)
# Change this if 3001 is already in use on your machine.
APP_PORT=3001

# Internal port for the Next.js server (inside container)
PORT=3000

# Redis connection URL
REDIS_URL=redis://redis:6379

# Data directory (SQLite DB, assets, config, backups)
DATA_DIR=/data

# Master encryption key (hex, 64 chars = 32 bytes)
# If not set, auto-generated and saved to DATA_DIR/config/master.key
# MASTER_KEY=

# License key (Ed25519 signed JWT)
# LICENSE_KEY=

# Logging level (debug, info, warn, error)
LOG_LEVEL=info

# Optional: comma-separated CIDR allowlist (e.g., 192.168.1.0/24,10.0.0.1)
# If set, only these IPs can access the app
# ALLOWED_IPS=

# Set to "true" if running behind a reverse proxy (to read X-Forwarded-For)
# TRUST_PROXY=false

# Max concurrent prediction jobs
MAX_CONCURRENT_NODES=5
