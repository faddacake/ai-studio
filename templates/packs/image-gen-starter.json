{
  "manifest": {
    "id": "image-gen-starter",
    "name": "Image Gen Starter",
    "version": "1.0.0",
    "author": "AI Studio",
    "description": "A minimal two-node starting point: type a prompt and generate an image.",
    "category": "getting-started",
    "tags": ["starter", "image", "beginner", "prompt"],
    "templates": ["prompt-to-image"],
    "previews": {
      "prompt-to-image": "Two nodes: Prompt Template → Image Generation. The simplest possible image workflow."
    },
    "requiredNodeTypes": ["image-generation"],
    "source": "builtin"
  },
  "templates": {
    "prompt-to-image": {
      "version": 1,
      "nodes": [
        {
          "id": "00000000-0000-4000-e000-000000000001",
          "type": "prompt-template",
          "position": { "x": 0, "y": 200 },
          "data": {
            "label": "Prompt",
            "params": {
              "__nodeType": "prompt-template",
              "template": "A photorealistic image of {{subject}}"
            },
            "retryCount": 0,
            "timeoutMs": 10000
          },
          "inputs": [],
          "outputs": [
            { "id": "text_out", "name": "Text", "type": "text", "direction": "output" }
          ]
        },
        {
          "id": "00000000-0000-4000-e000-000000000002",
          "type": "image-generation",
          "position": { "x": 340, "y": 200 },
          "data": {
            "label": "Image Generation",
            "params": {
              "__nodeType": "image-generation",
              "width": 1024,
              "height": 1024,
              "num_inference_steps": 28,
              "guidance_scale": 7.5,
              "seed": -1
            },
            "retryCount": 1,
            "timeoutMs": 300000
          },
          "inputs": [
            { "id": "prompt_in", "name": "Prompt", "type": "text", "direction": "input" }
          ],
          "outputs": [
            { "id": "image_out", "name": "Image", "type": "image", "direction": "output" }
          ]
        }
      ],
      "edges": [
        {
          "id": "00000000-0000-4000-f000-000000000001",
          "source": "00000000-0000-4000-e000-000000000001",
          "sourceHandle": "text_out",
          "target": "00000000-0000-4000-e000-000000000002",
          "targetHandle": "prompt_in"
        }
      ]
    }
  }
}
